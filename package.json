{
  "name": "cellfocus",
  "version": "1.0.0",
  "description": "Excel Add-in for focused cell range editing",
  "scripts": {
    "dev": "webpack serve --mode development",
    "test": "node --experimental-vm-modules --test test/*.test.mjs",
    "build": "webpack --mode production",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build:customer": "npm run build && node scripts/generate-customer-manifest.mjs --label customer",
    "build:marketplace": "npm run build && node scripts/generate-customer-manifest.mjs --label marketplace",
    "build:github-pages": "npm run build:marketplace -- --base-url https://younnieCutler.github.io/excel-new-tab-cell-range --support-url https://younnieCutler.github.io/excel-new-tab-cell-range/support.html",
    "start": "concurrently \"npm run dev\" \"office-addin-debugging start manifest.dev.xml desktop\"",
    "stop": "office-addin-debugging stop manifest.dev.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "validate:customer": "office-addin-manifest validate dist/manifest.xml",
    "validate:marketplace": "office-addin-manifest validate -p dist/manifest.xml"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "mini-css-extract-plugin": "^2.7.6",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.9.1",
    "office-addin-manifest": "^1.10.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
